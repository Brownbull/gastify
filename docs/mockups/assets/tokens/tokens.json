{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$name": "gastify Design Tokens",
  "$version": "2.0.0",
  "$date": "2026-04-23",
  "$phase": "Phase 1 exit — UX mockups tier: ent (escalated from mvp per D7)",
  "$description": "Runtime multi-theme token system for gastify. 3 themes × 2 modes = 6 variants. Themes (Normal/Professional/Mono) swap surface + primary + accent palette; modes (Light/Dark) invert ink + surface. CSS exposes via :root + [data-theme][data-mode] selectors in docs/mockups/assets/css/desktop-shell.css.",

  "font": {
    "family": {
      "body":    { "$value": "'Outfit', system-ui, -apple-system, sans-serif", "$description": "Variable 400-800 — self-hosted woff2 at assets/fonts/" },
      "display": { "$value": "'Baloo 2', cursive",                              "$description": "Display / wordmark / h1 / large numeric — 700 only" },
      "mono":    { "$value": "'Outfit', monospace",                              "$description": "Numeric tabular via font-variant-numeric: tabular-nums" }
    },
    "weight": {
      "regular":  { "$value": 400 },
      "medium":   { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold":     { "$value": 700 }
    },
    "size": {
      "xs":   { "$value": "11px" },
      "sm":   { "$value": "12px" },
      "base": { "$value": "13px" },
      "md":   { "$value": "14px" },
      "lg":   { "$value": "15px" },
      "xl":   { "$value": "16px" },
      "2xl":  { "$value": "18px" },
      "3xl":  { "$value": "22px" },
      "4xl":  { "$value": "28px" },
      "5xl":  { "$value": "32px" },
      "6xl":  { "$value": "38px" },
      "7xl":  { "$value": "44px" }
    },
    "line-height": {
      "tight":  { "$value": 1.1 },
      "snug":   { "$value": 1.2 },
      "normal": { "$value": 1.5 },
      "relaxed":{ "$value": 1.6 }
    },
    "letter-spacing": {
      "tight":    { "$value": "-0.02em" },
      "snug":     { "$value": "-0.01em" },
      "normal":   { "$value": "0" },
      "wide":     { "$value": "0.04em" },
      "wider":    { "$value": "0.08em" },
      "widest":   { "$value": "0.14em" }
    }
  },

  "space": {
    "1":  { "$value": "4px" },
    "2":  { "$value": "6px" },
    "3":  { "$value": "8px" },
    "4":  { "$value": "10px" },
    "5":  { "$value": "12px" },
    "6":  { "$value": "14px" },
    "7":  { "$value": "16px" },
    "8":  { "$value": "18px" },
    "9":  { "$value": "20px" },
    "10": { "$value": "24px" },
    "12": { "$value": "28px" },
    "14": { "$value": "32px" },
    "16": { "$value": "40px" },
    "20": { "$value": "48px" },
    "24": { "$value": "60px" },
    "32": { "$value": "80px" }
  },

  "radius": {
    "sm":   { "$value": "4px" },
    "md":   { "$value": "6px" },
    "lg":   { "$value": "8px" },
    "xl":   { "$value": "10px" },
    "2xl":  { "$value": "12px" },
    "3xl":  { "$value": "14px" },
    "4xl":  { "$value": "16px" },
    "5xl":  { "$value": "18px" },
    "6xl":  { "$value": "20px" },
    "pill": { "$value": "999px" },
    "round":{ "$value": "50%" }
  },

  "shadow": {
    "sm":  { "$value": "0 1px 3px var(--shadow)" },
    "md":  { "$value": "0 2px 4px var(--shadow)" },
    "lg":  { "$value": "0 2px 8px var(--shadow)" },
    "xl":  { "$value": "0 4px 16px var(--shadow-lg)" },
    "2xl": { "$value": "0 12px 32px var(--shadow-lg)" }
  },

  "breakpoint": {
    "mobile":     { "$value": "640px",  "$description": "Mobile Web PWA fallback" },
    "tablet":     { "$value": "1024px", "$description": "Sidebar collapses to horizontal pills" },
    "desktop":    { "$value": "1280px", "$description": "Right rail drops" },
    "wide":       { "$value": "1440px", "$description": "Max app-shell width (standard desktop)" },
    "ultrawide":  { "$value": "1600px", "$description": "Group Hub 4-col max width" }
  },

  "theme": {
    "normal": {
      "$description": "Warm forest — brand-invariant default. Wordmark lives here at Baloo 2 700 24px primary.",
      "light": {
        "bg":            { "$value": "#f5f0e8" },
        "surface":       { "$value": "#ffffff" },
        "surface-2":     { "$value": "#f1dbb6" },
        "ink":           { "$value": "#2d3a4a" },
        "ink-2":         { "$value": "#4a5568" },
        "ink-3":         { "$value": "#8a9488" },
        "line":          { "$value": "#e3bba1" },
        "line-strong":   { "$value": "#d4a574" },
        "primary":       { "$value": "#4a7c59" },
        "primary-ink":   { "$value": "#ffffff" },
        "primary-soft":  { "$value": "#dcefd9" },
        "accent":        { "$value": "#e8a87c" },
        "accent-soft":   { "$value": "#fdeccc" },
        "success":       { "$value": "#7d9b5f" },
        "warning":       { "$value": "#f59e0b" },
        "error":         { "$value": "#c1392b" },
        "danger-soft":   { "$value": "#f7dad6" },
        "secondary":     { "$value": "#5b8fa8" },
        "shadow":        { "$value": "rgba(74, 124, 89, 0.12)" },
        "shadow-lg":     { "$value": "rgba(74, 124, 89, 0.18)" }
      },
      "dark": {
        "bg":            { "$value": "#1a2420" },
        "surface":       { "$value": "#243028" },
        "surface-2":     { "$value": "#2d3a30" },
        "ink":           { "$value": "#e8e4dc" },
        "ink-2":         { "$value": "#b8c4a8" },
        "ink-3":         { "$value": "#8a9488" },
        "line":          { "$value": "#3d4d42" },
        "line-strong":   { "$value": "#4d5d52" },
        "primary":       { "$value": "#6b9e7a" },
        "primary-ink":   { "$value": "#ffffff" },
        "primary-soft":  { "$value": "rgba(107, 158, 122, 0.15)" },
        "accent":        { "$value": "#d4a574" },
        "accent-soft":   { "$value": "rgba(212, 165, 116, 0.15)" },
        "success":       { "$value": "#9bbd7f" },
        "warning":       { "$value": "#fbbf24" },
        "error":         { "$value": "#f87171" },
        "danger-soft":   { "$value": "rgba(248, 113, 113, 0.12)" },
        "secondary":     { "$value": "#7ab5cc" },
        "shadow":        { "$value": "rgba(0,0,0,0.3)" },
        "shadow-lg":     { "$value": "rgba(0,0,0,0.5)" }
      }
    },
    "professional": {
      "$description": "Cool blue — enterprise / B2B variant.",
      "light": {
        "bg": { "$value": "#f8fafc" }, "surface": { "$value": "#ffffff" }, "surface-2": { "$value": "#f1f5f9" },
        "ink": { "$value": "#0f172a" }, "ink-2": { "$value": "#475569" }, "ink-3": { "$value": "#94a3b8" },
        "line": { "$value": "#e2e8f0" }, "line-strong": { "$value": "#cbd5e1" },
        "primary": { "$value": "#2563eb" }, "primary-ink": { "$value": "#ffffff" }, "primary-soft": { "$value": "#dbeafe" },
        "accent": { "$value": "#3b82f6" }, "accent-soft": { "$value": "#eff6ff" },
        "success": { "$value": "#16a34a" }, "warning": { "$value": "#d97706" }, "error": { "$value": "#dc2626" },
        "danger-soft": { "$value": "#fee2e2" }, "secondary": { "$value": "#0ea5e9" },
        "shadow": { "$value": "rgba(37, 99, 235, 0.08)" }, "shadow-lg": { "$value": "rgba(37, 99, 235, 0.14)" }
      }
    },
    "mono": {
      "$description": "Grayscale — accessibility-first / print-friendly variant.",
      "light": {
        "bg": { "$value": "#fafafa" }, "surface": { "$value": "#ffffff" }, "surface-2": { "$value": "#f4f4f5" },
        "ink": { "$value": "#18181b" }, "ink-2": { "$value": "#52525b" }, "ink-3": { "$value": "#a1a1aa" },
        "line": { "$value": "#e4e4e7" }, "line-strong": { "$value": "#d4d4d8" },
        "primary": { "$value": "#18181b" }, "primary-ink": { "$value": "#ffffff" }, "primary-soft": { "$value": "#f4f4f5" },
        "accent": { "$value": "#52525b" }, "accent-soft": { "$value": "#e4e4e7" },
        "success": { "$value": "#16a34a" }, "warning": { "$value": "#d97706" }, "error": { "$value": "#dc2626" },
        "danger-soft": { "$value": "#fee2e2" }, "secondary": { "$value": "#71717a" },
        "shadow": { "$value": "rgba(0,0,0,0.08)" }, "shadow-lg": { "$value": "rgba(0,0,0,0.14)" }
      }
    }
  },

  "category-palette": {
    "$description": "V4 taxonomy palette — theme-agnostic at L1 Rubro level. Full L1-L4 color scales live in assets/tokens/storeColors.ts + itemColors.ts + groupColors.ts (ported from BoletApp).",
    "hogar":        { "base": { "$value": "#4a7c59" }, "tint": { "$value": "rgba(74, 124, 89, 0.15)" } },
    "medicamento":  { "base": { "$value": "#dc2626" }, "tint": { "$value": "rgba(220, 38, 38, 0.12)" } },
    "cargo":        { "base": { "$value": "#d97706" }, "tint": { "$value": "rgba(217, 119, 6, 0.12)" } },
    "mascotas":     { "base": { "$value": "#5b8fa8" }, "tint": { "$value": "rgba(91, 143, 168, 0.12)" } },
    "taxonomy-levels": {
      "L1": { "$description": "12 Rubros — storeGroups", "count": 12, "source": "assets/tokens/storeColors.ts" },
      "L2": { "$description": "44 Giros — storeCategories", "count": 44, "source": "assets/tokens/storeColors.ts" },
      "L3": { "$description": "9 Familias — itemGroups", "count": 9, "source": "assets/tokens/groupColors.ts" },
      "L4": { "$description": "42 Categorías — itemCategories", "count": 42, "source": "assets/tokens/itemColors.ts" }
    }
  },

  "wordmark": {
    "$description": "BRAND-INVARIANT. Never re-theme. Same across all 6 variants + all platforms.",
    "font-family": { "$value": "'Baloo 2', cursive" },
    "font-weight": { "$value": 700 },
    "font-size":   { "$value": "24px" },
    "color":       { "$value": "var(--primary)" },
    "letter-spacing": { "$value": "0" }
  },

  "motion": {
    "duration": {
      "fast":   { "$value": "120ms" },
      "base":   { "$value": "150ms" },
      "slow":   { "$value": "200ms" },
      "slower": { "$value": "300ms" }
    },
    "easing": {
      "out":    { "$value": "ease-out" },
      "in-out": { "$value": "ease-in-out" }
    },
    "prefers-reduced-motion": {
      "$description": "Animations disable when user has reduced-motion preference. Filter-pulse + scanline + welcome-bounce all respect."
    }
  },

  "z-index": {
    "base":    { "$value": 1 },
    "sticky":  { "$value": 20 },
    "dropdown":{ "$value": 50 },
    "modal":   { "$value": 70 },
    "popover": { "$value": 100 },
    "controls":{ "$value": 9999 }
  }
}
