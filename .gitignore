# Receipt prompt lab generated model outputs. Test cases and docs are committed.
prompt-testing/cache/**
prompt-testing/results/**
prompt-testing/import-manifest*.json
!prompt-testing/cache/.gitkeep
!prompt-testing/results/latest/
!prompt-testing/results/latest/.gitkeep
!prompt-testing/results/archive/
!prompt-testing/results/archive/.gitkeep

# Statement prompt lab private corpus. Commit only sanitized manifests/docs/schemas.
prompt-testing/test-cases/statements/private/**
prompt-testing/test-cases/statements/**/credentials.json

# Mockup reference dump — unversioned scratch vault for legacy imports (Claude Design, BoletApp, etc.)
docs/mockups/legacy-reference/

# NOTE: Generated files under shared/ (categories.py, categories.ts, constants.py,
# constants.ts, api-types.ts) ARE committed intentionally. CI runs codegen and
# diff-checks against committed versions to catch drift. See PLAN.md B3 + LESSONS R6.
tests/mockups/validate/.cache/

# Mobile E2E results. Keep docs/scripts in git, not generated screenshots.
tests/mobile/results/latest/**
tests/mobile/results/archive/**
tests/mobile/results/runs/**
# Legacy mobile E2E artifact path; kept ignored for old local shells.
tests/mobile/artifacts/latest/**
tests/mobile/artifacts/archive/**
tests/mobile/artifacts/runs/**

# Firestore data exports — contain real user PII (emails, UIDs)
docs/rebuild/firestore-data-export.json
docs/rebuild/FIRESTORE-EXPORT.json

# Web e2e proof screenshots (regenerable via capture-proof.spec.ts)
tests/web-e2e/proof/
tests/web-e2e/test-results/
playwright-report/
design-lab/storybook-static/
