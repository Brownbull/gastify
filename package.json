{
  "name": "gastify",
  "version": "0.0.0",
  "private": true,
  "description": "Gastify — smart personal expense tracker (mockup phase). Test harness for docs/mockups/.",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "serve:mockups": "http-server docs/mockups -p 4173 -c-1 --silent",
    "extract:dump": "node tests/legacy-extract/parse-dump.ts",
    "extract:legacy": "playwright test --config=tests/legacy-extract/playwright.legacy.config.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "http-server": "^14.1.1"
  }
}
