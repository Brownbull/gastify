# Copy to mobile/.env.production only when production provisioning starts.
# Production builds must not enable E2E auth or scan test controls.

EXPO_PUBLIC_APP_ENV=production
EXPO_PUBLIC_API_BASE_URL="https://<gastify-api-production-domain>"

EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID="<production-web-client-id>"
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID="<production-ios-client-id>"
EXPO_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=

EXPO_PUBLIC_E2E_AUTH_ENABLED=false
EXPO_PUBLIC_E2E_AUTH_MODE=staging
EXPO_PUBLIC_E2E_AUTH_EMAIL=
EXPO_PUBLIC_E2E_AUTH_PASSWORD=
EXPO_PUBLIC_SCAN_TEST_CONTROLS_ENABLED=false

GOOGLE_SERVICES_JSON=./google-services.production.json
GOOGLE_SERVICE_INFO_PLIST=./GoogleService-Info.production.plist

EXPO_DEV_CLIENT_URL=
