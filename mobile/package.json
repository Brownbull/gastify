{
  "name": "gastify-mobile",
  "version": "0.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:dev-client": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "eas:whoami": "npx eas-cli@latest whoami",
    "eas:build:android:dev": "npx eas-cli@latest build --platform android --profile development",
    "eas:build:android:staging": "npx eas-cli@latest build --platform android --profile staging",
    "eas:build:android:e2e-staging": "npx eas-cli@latest build --platform android --profile e2e-staging",
    "eas:build:android:e2e": "npx eas-cli@latest build --platform android --profile e2e",
    "eas:build:ios:e2e": "npx eas-cli@latest build --platform ios --profile e2e",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "check:expo-config": "bash ../tests/mobile/scripts/check-expo-config.sh",
    "doctor:e2e": "bash ../tests/mobile/scripts/doctor-mobile.sh",
    "verify:staging-auth": "bash ../tests/mobile/scripts/verify-staging-auth.sh",
    "maestro:open-dev-client": "bash ../tests/mobile/scripts/open-dev-client.sh",
    "maestro:install-driver": "bash ../tests/mobile/scripts/install-maestro-driver.sh",
    "maestro:reset-driver": "bash ../tests/mobile/scripts/reset-maestro-driver.sh",
    "maestro:smoke": "bash ../tests/mobile/scripts/run-maestro.sh",
    "maestro:smoke:active": "bash ../tests/mobile/scripts/run-maestro.sh tests/mobile/maestro/p4-phase1-smoke-active.yaml",
    "maestro:scan-entry:active": "bash ../tests/mobile/scripts/run-maestro.sh tests/mobile/maestro/p4-phase2-scan-entry-active.yaml",
    "seed:scan-fixtures": "bash ../tests/mobile/scripts/seed-scan-fixture.sh all",
    "maestro:scan-upload:live:active": "bash ../tests/mobile/scripts/run-maestro.sh tests/mobile/maestro/p4-phase2-scan-upload-live-active.yaml",
    "maestro:scan-upload:happy:active": "bash ../tests/mobile/scripts/run-scan-upload-maestro.sh happy",
    "maestro:scan-upload:review:active": "bash ../tests/mobile/scripts/run-scan-upload-maestro.sh review",
    "maestro:scan-upload:failure:active": "bash ../tests/mobile/scripts/run-scan-upload-maestro.sh failure",
    "maestro:camera-permission-denied:active": "bash ../tests/mobile/scripts/run-scan-upload-maestro.sh camera-denied",
    "maestro:phase5:golden:active": "bash ../tests/mobile/scripts/run-maestro.sh tests/mobile/maestro/p4-phase5-golden-journey-active.yaml",
    "maestro:statement:active": "bash ../tests/mobile/scripts/run-maestro.sh tests/mobile/maestro/p5-phase6-statement-reconciliation-active.yaml",
    "generate:api": "cd ../backend && uv run python -c \"from app.main import app; import json; f=open('../mobile/src/lib/openapi-spec.json','w'); json.dump(app.openapi(),f,indent=2)\" && cd ../mobile && npx openapi-typescript src/lib/openapi-spec.json -o src/lib/api-types.d.ts"
  },
  "dependencies": {
    "@react-native-firebase/app": "24.0.0",
    "@react-native-firebase/auth": "24.0.0",
    "@react-native-google-signin/google-signin": "16.1.2",
    "@react-navigation/native": "7.2.4",
    "@react-navigation/native-stack": "7.15.1",
    "@tanstack/react-query": "5.100.10",
    "expo": "55.0.24",
    "expo-constants": "55.0.16",
    "expo-dev-client": "~55.0.34",
    "expo-document-picker": "~55.0.13",
    "expo-image-picker": "~55.0.20",
    "expo-linear-gradient": "~55.0.14",
    "expo-notifications": "~55.0.23",
    "expo-secure-store": "55.0.14",
    "expo-status-bar": "55.0.6",
    "expo-system-ui": "~55.0.18",
    "openapi-fetch": "0.17.0",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-gifted-charts": "^1.4.77",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@testing-library/react-native": "13.3.3",
    "@types/jest": "29.5.14",
    "@types/node": "24.12.3",
    "@types/react": "19.2.14",
    "babel-preset-expo": "^55.0.21",
    "jest": "29.7.0",
    "openapi-typescript": "7.13.0",
    "react-test-renderer": "19.2.0",
    "typescript": "5.9.3"
  },
  "overrides": {
    "shell-quote": "^1.8.4",
    "ws": "^8.21.0",
    "protobufjs": "^7.6.4"
  }
}
