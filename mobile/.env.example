# Generic mobile template. Prefer copying the environment-specific template:
# - mobile/.env.local.example -> mobile/.env.local
# - mobile/.env.staging.example -> mobile/.env.staging
# - mobile/.env.staging-e2e.example -> mobile/.env.staging-e2e
# - mobile/.env.production.example -> mobile/.env.production

EXPO_PUBLIC_APP_ENV=local
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=

EXPO_PUBLIC_E2E_AUTH_ENABLED=false
EXPO_PUBLIC_E2E_AUTH_MODE=staging
EXPO_PUBLIC_E2E_AUTH_EMAIL=
EXPO_PUBLIC_E2E_AUTH_PASSWORD=
EXPO_PUBLIC_SCAN_TEST_CONTROLS_ENABLED=false

GOOGLE_SERVICES_JSON=./google-services.json
GOOGLE_SERVICE_INFO_PLIST=./GoogleService-Info.plist

# Local dev-client helper used by scripts/dev/run-s23-local-ui-smoke.sh.
EXPO_DEV_CLIENT_URL=
