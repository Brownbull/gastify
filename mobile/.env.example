# For a physical Android phone, use a staging API, LAN IP, or adb reverse.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_E2E_AUTH_ENABLED=false
EXPO_PUBLIC_E2E_AUTH_MODE=staging
EXPO_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=
EXPO_PUBLIC_E2E_AUTH_EMAIL=
EXPO_PUBLIC_E2E_AUTH_PASSWORD=

# Optional native Firebase files for EAS/prebuild.
GOOGLE_SERVICES_JSON=./google-services.json
GOOGLE_SERVICE_INFO_PLIST=./GoogleService-Info.plist
