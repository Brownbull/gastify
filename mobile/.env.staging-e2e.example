# Copy to mobile/.env.staging-e2e for deterministic S23 fixture proof.
# E2E auth values must be disposable staging-only credentials.

EXPO_PUBLIC_APP_ENV=staging-e2e
EXPO_PUBLIC_API_BASE_URL=https://gastify-api-staging-e2e-staging-e2e.up.railway.app

EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID="<staging-web-client-id>"
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID="<staging-ios-client-id>"
EXPO_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=

EXPO_PUBLIC_E2E_AUTH_ENABLED=true
EXPO_PUBLIC_E2E_AUTH_MODE=staging
EXPO_PUBLIC_E2E_AUTH_EMAIL="<staging-e2e-user-email>"
EXPO_PUBLIC_E2E_AUTH_PASSWORD="<staging-e2e-user-password>"
EXPO_PUBLIC_SCAN_TEST_CONTROLS_ENABLED=false

GOOGLE_SERVICES_JSON=./google-services.json
GOOGLE_SERVICE_INFO_PLIST=./GoogleService-Info.plist

EXPO_DEV_CLIENT_URL=
