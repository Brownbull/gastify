# Copy to mobile/.env.staging for live Gemini staging smoke.
# This points at the normal staging API and hides direct test controls by default.

EXPO_PUBLIC_APP_ENV=staging
EXPO_PUBLIC_API_BASE_URL=https://gastify-api-staging-staging.up.railway.app

EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID="<staging-web-client-id>"
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID="<staging-ios-client-id>"
EXPO_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=

EXPO_PUBLIC_E2E_AUTH_ENABLED=false
EXPO_PUBLIC_E2E_AUTH_MODE=staging
EXPO_PUBLIC_E2E_AUTH_EMAIL=
EXPO_PUBLIC_E2E_AUTH_PASSWORD=
EXPO_PUBLIC_SCAN_TEST_CONTROLS_ENABLED=false

GOOGLE_SERVICES_JSON=./google-services.json
GOOGLE_SERVICE_INFO_PLIST=./GoogleService-Info.plist

EXPO_DEV_CLIENT_URL=
