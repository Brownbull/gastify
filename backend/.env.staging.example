# Copy to backend/.env.staging for staging commands, or mirror these values into
# Railway service variables for gastify-api-staging.
# Do not commit the copied file.

GASTIFY_ENVIRONMENT=staging
GASTIFY_SCAN_PROVIDER=gemini
GASTIFY_DATABASE_URL="<staging-railway-postgres-url>"
GASTIFY_DATABASE_ECHO=false
GASTIFY_SCAN_STORAGE_DIR=/data/scans

GASTIFY_FIREBASE_PROJECT_ID=gastify-staging
GASTIFY_FIREBASE_CREDENTIALS_PATH=
GASTIFY_FIREBASE_CREDENTIALS_JSON='<one-line-staging-service-account-json>'

GASTIFY_CORS_ORIGINS='["https://gastify-web-staging-staging.up.railway.app","http://localhost:5173","http://localhost:5174"]'
GASTIFY_FX_API_URL=https://api.frankfurter.dev

GASTIFY_SCAN_EVENT_BUFFER_SIZE=32
GASTIFY_SCAN_EVENT_HEARTBEAT_INTERVAL_S=15

GASTIFY_GEMINI_MODEL=gemini-2.5-flash-lite
GASTIFY_GEMINI_MAX_RETRIES=3
GASTIFY_GEMINI_RETRY_DELAY_SECONDS=2
GASTIFY_RECEIPT_EXTRACTION_PROMPT_ID=receipt-extraction-current
GASTIFY_ITEM_CATEGORIZATION_PROMPT_ID=item-categorization-current
# Optional threshold override; built-in default matches backend/app/reference/receipt_validation_policy_v1.json.
GASTIFY_RECEIPT_VALIDATION_POLICY_PATH=
GOOGLE_API_KEY="<paste-staging-gemini-api-key-here>"

GASTIFY_E2E_SCAN_FIXTURES_ENABLED=false
GASTIFY_E2E_SCAN_EVENT_DELAY_MS=0
GASTIFY_E2E_AUTH_ENABLED=false
GASTIFY_SCAN_TEST_CONTROLS_ENABLED=false
GASTIFY_SCAN_TEST_ALLOWED_EMAILS='["<disposable-staging-user@example.test>"]'
GASTIFY_DEBUG=false
