# Copy to backend/.env.production only when production provisioning starts.
# Production must never enable mock, fixture, SQLite, E2E auth, or scan test controls.

GASTIFY_ENVIRONMENT=production
GASTIFY_SCAN_PROVIDER=gemini
# Two-role DB split for RLS enforcement (P43; Gustify D32) — both NON-superuser.
# Runtime = gastify_app (table CRUD, RLS applies; startup guard rejects bypass).
# Migrations = gastify_migrator (owns tables, runs DDL). See the runbook.
GASTIFY_DATABASE_URL="postgresql://gastify_app:<app-pw>@<prod-pg-host>:5432/<db>"
GASTIFY_MIGRATION_DATABASE_URL="postgresql://gastify_migrator:<mig-pw>@<prod-pg-host>:5432/<db>"
GASTIFY_DATABASE_ECHO=false
GASTIFY_SCAN_STORAGE_DIR=/data/scans

GASTIFY_FIREBASE_PROJECT_ID="<production-firebase-project-id>"
GASTIFY_FIREBASE_CREDENTIALS_PATH=
GASTIFY_FIREBASE_CREDENTIALS_JSON='<one-line-production-service-account-json>'

GASTIFY_CORS_ORIGINS='["https://<production-web-domain>"]'
GASTIFY_FX_API_URL=https://api.frankfurter.dev

GASTIFY_SCAN_EVENT_BUFFER_SIZE=32
GASTIFY_SCAN_EVENT_HEARTBEAT_INTERVAL_S=15

GASTIFY_GEMINI_MODEL=gemini-2.5-flash-lite
GASTIFY_GEMINI_MAX_RETRIES=3
GASTIFY_GEMINI_RETRY_DELAY_SECONDS=2
GASTIFY_RECEIPT_EXTRACTION_PROMPT_ID=receipt-extraction-current
GASTIFY_ITEM_CATEGORIZATION_PROMPT_ID=item-categorization-current
GOOGLE_API_KEY="<paste-production-gemini-api-key-here>"

GASTIFY_E2E_SCAN_FIXTURES_ENABLED=false
GASTIFY_E2E_SCAN_EVENT_DELAY_MS=0
GASTIFY_E2E_AUTH_ENABLED=false
GASTIFY_SCAN_TEST_CONTROLS_ENABLED=false
GASTIFY_SCAN_TEST_ALLOWED_EMAILS='[]'
GASTIFY_DEBUG=false
