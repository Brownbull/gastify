{
  "name": "gastify-design-lab",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "React + Storybook mockup workspace — desktop/tablet/mobile design surface for gastify (PLAN-MOCKUPS). Tokens from shared/design-tokens.ts; artifacts later wire into web/ and mobile/.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "generate:tokens": "node scripts/generate-tokens-css.mjs",
    "storybook": "storybook dev -p 6008",
    "build-storybook": "storybook build",
    "test": "vitest run --project unit --passWithNoTests",
    "test-storybook": "vitest run --project storybook"
  },
  "dependencies": {
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/browser-playwright": "^4.1.5",
    "jsdom": "^25.0.1",
    "playwright": "^1.56.1",
    "storybook": "^10.3.5",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.3",
    "vite": "^7.0.0",
    "vitest": "^4.1.5"
  }
}
