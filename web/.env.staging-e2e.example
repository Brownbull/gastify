# Optional local/debug web config pointing at deterministic staging-e2e API.
# The deployed Railway web service should normally use web/.env.staging values.

VITE_API_BASE_URL=https://gastify-api-staging-e2e-staging.up.railway.app

VITE_FIREBASE_API_KEY="<staging-firebase-web-api-key>"
VITE_FIREBASE_AUTH_DOMAIN="<staging-firebase-auth-domain>"
VITE_FIREBASE_PROJECT_ID=gastify-staging
VITE_FIREBASE_STORAGE_BUCKET="<staging-firebase-storage-bucket>"
VITE_FIREBASE_MESSAGING_SENDER_ID="<staging-firebase-messaging-sender-id>"
VITE_FIREBASE_APP_ID="<staging-firebase-web-app-id>"
